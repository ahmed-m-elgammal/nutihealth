# n8n local runtime
TZ=Africa/Cairo
GENERIC_TIMEZONE=Africa/Cairo
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/

# Optional basic auth in local development
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-local

# AI provider keys (used by workflows and/or credential setup)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_FITNESS_MODEL=openai/gpt-4o-mini
OPENROUTER_CHAT_COMPLETIONS_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_SITE_URL=http://localhost:5678
OPENROUTER_APP_NAME=NutriHealth n8n Local

# Optional fallback / legacy key
GROQ_API_KEY=

# Hugging Face is still used by Voice-to-Text (Whisper)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
