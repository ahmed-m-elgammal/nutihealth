# Public DNS/domain for n8n webhook URLs
N8N_HOST=api.nutihealth.com
WEBHOOK_URL=https://api.nutihealth.com/

# n8n auth
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-prod

# PostgreSQL settings
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-db

# AI provider keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_FITNESS_MODEL=openai/gpt-4o-mini
OPENROUTER_CHAT_COMPLETIONS_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_SITE_URL=https://api.nutihealth.com
OPENROUTER_APP_NAME=NutriHealth n8n

# Optional fallback / legacy key
GROQ_API_KEY=

# Hugging Face is still used by Voice-to-Text (Whisper)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Timezone
TZ=UTC
GENERIC_TIMEZONE=UTC
