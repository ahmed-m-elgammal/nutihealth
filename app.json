{
  "expo": {
    "name": "NutriHealth",
    "slug": "nutrihealth",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "scheme": "nutrihealth",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "assets/**"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nutrihealth.app",
      "infoPlist": {
        "NSCameraUsageDescription": "NutriHealth needs access to your camera to scan barcodes and take food photos.",
        "NSPhotoLibraryUsageDescription": "NutriHealth needs access to your photo library to save and load meal photos.",
        "NSMotionUsageDescription": "NutriHealth uses motion data to better estimate your calorie burn during activities."
      }
    },
    "android": {
      "icon": "./assets/icon.png",
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nutrihealth.app",
      "versionCode": 1,
      "allowBackup": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "nutrihealth.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.nutrihealth.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "@morrowdigital/watermelondb-expo-plugin",
        {
          "disableJsi": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NutriHealth to access your camera to scan barcodes and take food photos.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#22c55e"
        }
      ],
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": [
              "armeabi-v7a",
              "arm64-v8a",
              "x86",
              "x86_64"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6928fe31-f31e-47d7-8f25-d7f15c433563"
      }
    }
  }
}