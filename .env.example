# Public Expo environment variables (safe to include in client builds)
EXPO_PUBLIC_OPENFOODFACTS_USER_AGENT=NutriHealth/1.0.0
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Must match backend APP_API_KEY
EXPO_PUBLIC_PROXY_API_KEY=replace_with_long_random_proxy_key

# Supabase client configuration for direct mobile sync/auth
# Use anon or publishable key only (never service role or personal access tokens)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_anon_or_publishable_key
