# NutriHealth Frontend Environment Variables
# Copy this file to .env and fill in the values

# Supabase Configuration
# The URL of your Supabase project (e.g., https://xyzcompany.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=

# The public anon key for your Supabase project
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Alternatively, use publishable key
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Backend API Configuration
# The URL where your backend Node.js server is running
EXPO_PUBLIC_API_URL=https://staging-api.nutrihealth.app/api

# Backend requests use the signed user session token (Bearer auth).
# No shared frontend API key is required.

# Remote push notifications (optional)
# Keep false for local-only reminders; set true only when backend + FCM are configured.
EXPO_PUBLIC_ENABLE_REMOTE_PUSH=false
# Relative API path (or full URL) that accepts Expo push tokens from authenticated users.
EXPO_PUBLIC_PUSH_TOKEN_PATH=/notifications/expo-token

# Third-Party APIs (Optional depending on usage)
# USDA FoodData Central API Key (if fetching directly from frontend)
EXPO_PUBLIC_USDA_API_KEY=

# n8n AI webhooks (optional)
# If set, frontend AI services will call these webhooks directly before falling back to /chat.
EXPO_PUBLIC_N8N_MEAL_PLANNER_URL=
EXPO_PUBLIC_N8N_FITNESS_ADVICE_URL=
EXPO_PUBLIC_N8N_VOICE_TO_TEXT_URL=

# Hugging Face Configuration (if not using backend proxy)
EXPO_PUBLIC_HF_API_TOKEN=
EXPO_PUBLIC_HF_PROXY_URL=
