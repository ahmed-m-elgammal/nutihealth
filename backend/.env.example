# NutriHealth Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
REQUEST_JSON_LIMIT=6mb

# Security
# Require authenticated user sessions (Bearer token) for /api routes.
# Set to false only for local testing scenarios.
REQUIRE_API_SESSION=true
# Comma-separated allowlist of exact web origins allowed by CORS.
# Example: CORS_ALLOWED_ORIGINS=https://app.nutrihealth.app,https://staging.nutrihealth.app
CORS_ALLOWED_ORIGINS=
# Local-only fallback. Keep false in deployed/staging environments.
CORS_ALLOW_LOCALHOST_FALLBACK=true

# Supabase Admin Access
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI & Third-Party APIs
# OpenRouter (OpenAI-compatible) for chat + nutrition estimation
OPENROUTER_API_KEY=
OPENROUTER_CHAT_COMPLETIONS_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_NUTRITION_MODEL=openai/gpt-4o-mini
OPENROUTER_NUTRITION_TIMEOUT_MS=15000
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_TIMEOUT_MS=45000
# Optional but recommended by OpenRouter
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=NutriHealth Backend

# Legacy fallback (kept for compatibility with older deployments)
GROQ_API_KEY=
GROQ_NUTRITION_MODEL=llama3-70b-8192
GROQ_NUTRITION_TIMEOUT_MS=15000

# Hugging Face API Token for food image detection
HF_API_TOKEN=
HF_FOOD_MODEL=google/vit-base-patch16-224-in21k-finetuned-food101
HF_FOOD_TIMEOUT_MS=20000
HF_AUTH_FAILURE_COOLDOWN_MS=600000

# OpenWeatherMap API Key for weather-based meal suggestions
OPENWEATHER_API_KEY=

# Rate Limiting (Optional Overrides)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# AI_RATE_LIMIT_WINDOW_MS=3600000
# AI_RATE_LIMIT_MAX=20
# RECIPE_RATE_LIMIT_WINDOW_MS=3600000
# RECIPE_RATE_LIMIT_MAX=50
