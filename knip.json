{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "entry": [
        "index.ts",
        "index.web.tsx",
        "src/app/**/*.{ts,tsx,js,jsx}",
        "app.json",
        "metro.config.js",
        "babel.config.js",
        "tailwind.config.js",
        "jest.config.js",
        "jest.setup.js",
        ".eslintrc.js",
        ".prettierrc.js"
    ],
    "project": [
        "src/**/*.{ts,tsx,js,jsx}"
    ],
    "ignore": [
        "node_modules/**",
        "android/**",
        "ios/**",
        "dist/**"
    ]
}